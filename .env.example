# ── Copy this file to .env and fill in your values ───────────────────────────
# Docker Compose reads .env automatically from the same directory.

# MariaDB root password (only used internally by the db container)
DB_ROOT_PASSWORD=change_me_root

# Application DB credentials — must match between db and server services
DB_NAME=f3_production
DB_USER=f3user
DB_PASS=change_me_db_password

# JWT secret — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret_string

# Host port the app is reachable on (maps to container port 3001)
PORT=3001
